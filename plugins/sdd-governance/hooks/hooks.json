{
  "hooks": [
    {
      "event": "UserPromptSubmit",
      "matcher": {},
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/governance-preflight.cjs",
      "description": "4-step pre-flight constitutional compliance check on every user message"
    },
    {
      "event": "PreToolUse",
      "matcher": {
        "tool_name": "Bash"
      },
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/git-safety-gate.sh",
      "description": "Gate git operations requiring user approval (Principle VI)"
    },
    {
      "event": "PostToolUse",
      "matcher": {},
      "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/rl-metrics-capture.sh",
      "description": "Capture skill success/failure for per-plugin RL metrics"
    }
  ]
}
