#!/usr/bin/env bash
# LogicLoom off-host git-approval adapter — pre-push hook.
# Enforces Principle VI (no autonomous git mutation) when git runs OUTSIDE
# Claude Code. A push is always a mutating, remote-affecting op, so it is gated.
# Install: git config core.hooksPath .logic-loom/adapters/githooks
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck disable=SC1090
. "$DIR/../git-approval-gate.sh"
if loom_git_approval_gate "git push"; then
  exit 0
fi
echo "Push blocked by the LogicLoom git-approval gate (Principle VI)." >&2
echo "Approve explicitly: LOOM_GIT_APPROVED=1 git push   (or run interactively)." >&2
exit 1
