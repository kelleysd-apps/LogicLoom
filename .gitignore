# Environment variables
.env

# Backup files
package.json.backup
*.backup

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.sublime-*

# OS files
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*

# Dependencies
node_modules/
package-lock.json

# Build outputs
dist/
build/
out/

# Secret management
retrieve-secrets.sh
secrets/
.secrets/

# Testing
coverage/
.nyc_output/

# Local development
.local/
*.local

# Structured Logging (ignore log files, keep structure)
.specify/logs/operations/*.log
.specify/logs/git-checkpoints/*.json
.specify/logs/parallel-sessions/*
!.specify/logs/README.md

# Context System Cache
.claude/context/.cache/*
# Session-specific audit logs (generated at runtime)
.docs/governance/audit/

# Backup files from edits
*.bak
.claude/skill-index.json.bak

# RL metrics (session-specific, regenerated)
# Keep the template but ignore session data
# .docs/rl-metrics/skill-performance.json  # Keep for now as template

# Feature specs (project-specific, created during development)
specs/*/
!specs/README.md
!specs/.gitkeep

# Deprecated items (kept locally for reference, not in template)
**/.deprecated/
