# Environment Configuration for LogicLoom

# Development Environment
NODE_ENV=development

# Add your project-specific environment variables below:
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# API_KEY=your_api_key_here
# JWT_SECRET=your_jwt_secret_here

# MCP Server Tokens (if needed)
# MCP_SUPABASE_TOKEN=your_token_here
# MCP_PERPLEXITY_KEY=your_key_here

# External Service APIs
# OPENAI_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here
# STRIPE_SECRET_KEY=your_key_here
# SENDGRID_API_KEY=your_key_here

# Cross-provider verification layer (delegated only — never orchestration):
#   - /research        : multi-LLM jury-on-demand tribunal voting
#   - /cross-check     : governed cross-provider adversarial reviewer
#                        (also the key-gated slot in /review-team and /plan-review).
# These keys are OPT-IN and off by default. Enabling a provider sends the review
# target (your diff/plan) to that provider's API — treat it as an explicit
# data-sharing decision for private code. With no key set, the cross-check slot
# fails open to "unavailable" and never blocks a review.
# OPENAI_API_KEY=your_openai_key_here    # Codex/GPT — default cross-check adversary
# GEMINI_API_KEY=your_gemini_key_here    # Gemini — alternate adversary lineage
# Optional model overrides (tier-style indirection, not pinned versions):
# CROSS_CHECK_OPENAI_MODEL=
# CROSS_CHECK_GEMINI_MODEL=
# Shared fallback (fills any single failed primary slot for /research)
# Free tier: console.mistral.ai — 2 req/min, 1B tokens/month, no credit card
# MISTRAL_API_KEY=your_mistral_key_here

# Feature Flags
# ENABLE_DEBUG_MODE=false
# ENABLE_ANALYTICS=true