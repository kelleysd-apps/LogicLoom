# Environment Configuration for SDD Agentic Framework

# Development Environment
NODE_ENV=development

# Add your project-specific environment variables below:
# DATABASE_URL=postgresql://user:pass@localhost:5432/dbname
# API_KEY=your_api_key_here
# JWT_SECRET=your_jwt_secret_here

# MCP Server Tokens (if needed)
# MCP_SUPABASE_TOKEN=your_token_here
# MCP_PERPLEXITY_KEY=your_key_here

# External Service APIs
# OPENAI_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here
# STRIPE_SECRET_KEY=your_key_here
# SENDGRID_API_KEY=your_key_here

# Multi-LLM Tribunal (/research command, /dev-loop tribunal voting)
# Primary providers (need at least 2 for tribunal)
# OPENAI_API_KEY=your_openai_key_here
# GEMINI_API_KEY=your_gemini_key_here
# Shared fallback (fills any single failed primary slot)
# Free tier: console.mistral.ai — 2 req/min, 1B tokens/month, no credit card
# MISTRAL_API_KEY=your_mistral_key_here

# Feature Flags
# ENABLE_DEBUG_MODE=false
# ENABLE_ANALYTICS=true