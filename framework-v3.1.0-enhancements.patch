+
+    # Display timing summary
+    printf "%-30s %-10s %-15s %-15s\n" "Operation" "Count" "Avg Duration" "Total Time"
+    printf "%-30s %-10s %-15s %-15s\n" "---------" "-----" "------------" "----------"
